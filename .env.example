# ============================================================
#  10-K RAG Studio — API keys
#  Copy this file to ".env" and fill in the keys you have.
#  ".env" is git-ignored and is NEVER committed.
#  You only need keys for the providers you actually use;
#  Google Gemini has a free tier and is the easiest start.
# ============================================================

# Google Gemini  (free tier) — https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# OpenAI (GPT)  — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# DeepSeek (OpenAI-compatible)  — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Kimi / Moonshot (OpenAI-compatible)  — https://platform.moonshot.cn/console/api-keys
MOONSHOT_API_KEY=

# Zhipu GLM (open-source GLM-4.5/4.6/5, OpenAI-compatible)  — https://open.bigmodel.cn/usercenter/apikeys
ZHIPU_API_KEY=

# Hugging Face (open-source models via Inference Providers / router)
#   token: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=

# Xiaomi MiMo (Token Plan, OpenAI-compatible)
XIAOMI_API_KEY=

# Anthropic Claude — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
